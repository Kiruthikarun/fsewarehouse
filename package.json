{
  "name": "t3c-warehouse",
  "version": "1.0.0",
  "private": true,
  "description": "Multi-tenant warehouse management platform — T3C FSE build exercise",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "db:seed": "tsx --env-file=.env prisma/seed.ts",
    "seed:scale": "tsx --env-file=.env scripts/seed-scale.ts",
    "seed:prod": "./scripts/seed-prod.sh",
    "verify:data": "tsx --env-file=.env scripts/verify-data.ts",
    "bq:setup": "tsx --env-file=.env scripts/setup-bigquery.ts",
    "bq:sync": "tsx --env-file=.env scripts/sync-to-bigquery.ts",
    "workos:provision": "tsx --env-file=.env scripts/provision-workos.ts",
    "auth:magic": "tsx --env-file=.env scripts/auth-email.ts magic",
    "auth:reset": "tsx --env-file=.env scripts/auth-email.ts reset"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@google-cloud/bigquery": "^7.9.1",
    "@mui/icons-material": "^9.0.1",
    "@mui/material": "^9.0.1",
    "@mui/material-nextjs": "^9.0.1",
    "@prisma/client": "^6.2.1",
    "@workos-inc/authkit-nextjs": "^2.0.0",
    "ag-grid-community": "^33.0.3",
    "ag-grid-react": "^33.0.3",
    "next": "^15.2.3",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "recharts": "^2.15.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.4",
    "@types/react-dom": "^19.0.2",
    "prisma": "^6.2.1",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20"
  }
}
