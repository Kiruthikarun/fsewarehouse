# ─────────────────────────────────────────────────────────────────────────────
# Copy to .env and fill in. NEVER commit .env. In production these come from
# Google Secret Manager (see README → Deploy), not from a file.
# ─────────────────────────────────────────────────────────────────────────────

# --- Transactional DB (Cloud SQL Postgres; local = docker-compose Postgres) ---
# Local dev (docker-compose up -d) — host port 5433 to avoid clashing with a
# local Postgres on 5432:
DATABASE_URL="postgresql://warehouse:warehouse@localhost:5433/warehouse?schema=public"
# Cloud Run via Cloud SQL connector uses a unix socket, e.g.:
# DATABASE_URL="postgresql://USER:PASS@localhost/warehouse?host=/cloudsql/PROJECT:REGION:INSTANCE"

# --- Auth mode -------------------------------------------------------------
# "dev"   -> cookie-based dev login that lists the 9 seeded users (no WorkOS needed).
# "workos"-> real WorkOS AuthKit. Required for the deployed instance.
AUTH_MODE="dev"

# --- WorkOS AuthKit (required when AUTH_MODE=workos) ------------------------
WORKOS_API_KEY="sk_test_..."
WORKOS_CLIENT_ID="client_..."
# Must be 32 bytes, base64. Generate: openssl rand -base64 32
WORKOS_COOKIE_PASSWORD="generate_a_32_byte_base64_secret_here"
# AuthKit redirect URI (must match the WorkOS dashboard config):
NEXT_PUBLIC_WORKOS_REDIRECT_URI="http://localhost:3000/api/auth/callback"

# --- BigQuery (analytics) --------------------------------------------------
GCP_PROJECT_ID="your-gcp-project"
BIGQUERY_DATASET="warehouse_analytics"
BIGQUERY_LOCATION="US"
# Local dev: path to a service-account key with BigQuery Data Editor + Job User.
# On Cloud Run leave this UNSET — the runtime service account is used via ADC.
GOOGLE_APPLICATION_CREDENTIALS="./secrets/bq-service-account.json"

# --- App -------------------------------------------------------------------
NODE_ENV="development"
